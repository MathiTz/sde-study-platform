generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts           Account[]
  sessions           Session[]
  dismissedResources DismissedResource[]
  questionAttempts   QuestionAttempt[]
  weekProgress       WeekProgress[]
  lessonProgress     UserLessonProgress[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Domain Models ─────────────────────────────────────────────

model Problem {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  difficulty    String   // EASY, MEDIUM, HARD
  description   String
  referenceData String // JSON: requirements, entities, api, architecture, deepDives, rubric
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sessions Session[]
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  problemId    String
  currentStep  String    @default("REQUIREMENTS") // REQUIREMENTS, CORE_ENTITIES, API_DESIGN, HIGH_LEVEL_DESIGN, DEEP_DIVES, COMPLETED
  status       String    @default("ACTIVE") // ACTIVE, PAUSED, COMPLETED
  timerElapsed Int       @default(0) // persisted elapsed seconds for current step timer
  overallScore Float?
  startedAt    DateTime  @default(now())
  completedAt  DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)
  steps   StepAttempt[]
}

model StepAttempt {
  id           String   @id @default(cuid())
  sessionId    String
  step         String   // REQUIREMENTS, CORE_ENTITIES, API_DESIGN, HIGH_LEVEL_DESIGN, DEEP_DIVES
  userInput    String // JSON: text content or Excalidraw scene data
  aiEvaluation String? // JSON: { score, feedback: { strengths, weaknesses, suggestions }, passed }
  passed       Boolean  @default(false)
  createdAt    DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ─── Knowledge Scraper ─────────────────────────────────────────

model KnowledgeEntry {
  id        String   @id @default(cuid())
  sourceUrl String
  title     String
  content   String // JSON: structured knowledge chunks
  tags      String   // comma-separated tags for topic matching
  createdAt DateTime @default(now())
}

// ─── Study Plan ───────────────────────────────────────────────

model StudyPlan {
  id          String   @id @default(cuid())
  title       String
  description String
  duration    Int      // weeks
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  weeks StudyWeek[]
}

model StudyWeek {
  id          String   @id @default(cuid())
  planId      String
  weekNumber  Int
  title       String
  description String
  topics      String   // comma-separated topics
  lessonId    String?  // Links to the related lesson in LESSONS
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())

  plan      StudyPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  questions StudyQuestion[]
  progress  WeekProgress[]
}

model StudyQuestion {
  id           String  @id @default(cuid())
  weekId       String
  questionType String  // SINGLE, MULTIPLE, ABSTRACT, DRAWING
  question     String  // The question text
  options      String? // JSON array for SINGLE/MULTIPLE: [{text, isCorrect}]
  hint         String? // Optional hint
  explanation  String? // Shown after answering
  topic        String  // Main topic this question covers
  difficulty   String  @default("INTERMEDIATE") // BEGINNER, INTERMEDIATE, ADVANCED

  week     StudyWeek      @relation(fields: [weekId], references: [id], onDelete: Cascade)
  attempts QuestionAttempt[]
}

model QuestionAttempt {
  id           String   @id @default(cuid())
  questionId   String
  userId       String
  userAnswer   String   // For SINGLE/MULTIPLE: selected option IDs. For ABSTRACT/DRAWING: text or scene data
  isCorrect    Boolean? // null for ABSTRACT/DRAWING until AI evaluates
  score        Float?   // AI score for ABSTRACT/DRAWING
  aiFeedback   String?  // JSON: {strengths, weaknesses, suggestions}
  createdAt    DateTime @default(now())

  question StudyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeekProgress {
  id           String   @id @default(cuid())
  weekId       String
  userId       String
  startedAt    DateTime @default(now())
  completedAt  DateTime?
  score        Float?
  attemptsCount Int      @default(0)

  week StudyWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weekId, userId])
}

// ─── Study Resources ───────────────────────────────────────────

model StudyResource {
  id           String   @id @default(cuid())
  title        String
  url          String
  source       String   // O'Reilly, Blog, GitHub, Paper, Documentation
  topics       String   // comma-separated tags for topic matching
  difficulty   String   // BEGINNER, INTERMEDIATE, ADVANCED
  description  String
  resourceType String   // ARTICLE, BOOK_CHAPTER, VIDEO, DOCUMENTATION
  createdAt    DateTime @default(now())

  dismissals DismissedResource[]
}

model DismissedResource {
  id         String   @id @default(cuid())
  userId     String
  resourceId String
  createdAt  DateTime @default(now())

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resource StudyResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceId])
}

// ─── Lesson Progress ────────────────────────────────────────────

model UserLessonProgress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String   // Matches the lesson id in lib/lessons/index.ts
  readAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
}
